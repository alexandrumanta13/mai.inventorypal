# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3000
APP_NAME=InventoryPal Email Platform

# ============================================
# DATABASE (MySQL Cloudways)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_secure_password
DB_DATABASE=inventorypal_email
DB_LOGGING=false
DB_SYNCHRONIZE=false

# ============================================
# REDIS (Cloudways)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# EMAIL VERIFICATION CONFIG
# IMPORTANT: Nu trimite emailuri! Doar verifică dacă exist mailbox-ul
# ============================================
EMAIL_VERIFICATION_HELO_DOMAIN=mail-check.tau-domeniu.ro
EMAIL_VERIFICATION_MAIL_FROM=verify@mail-check.tau-domeniu.ro
EMAIL_VERIFICATION_TIMEOUT=10000

# ============================================
# BULLMQ QUEUE
# ============================================
BULLMQ_CONCURRENCY=50
BULLMQ_RATE_LIMIT_MAX=100
BULLMQ_RATE_LIMIT_DURATION=1000

# ============================================
# IMPORT CONFIG
# ============================================
JSON_PAGES_PATH=/Users/alexmanta/Developer/sem/json_pages
IMPORT_BATCH_SIZE=10000

# InventoryPal MySQL connection
INVENTORYPAL_DB_HOST=localhost
INVENTORYPAL_DB_PORT=3306
INVENTORYPAL_DB_USERNAME=root
INVENTORYPAL_DB_PASSWORD=your_password
INVENTORYPAL_DB_DATABASE=jscnaxugss

# ============================================
# JWT AUTH
# ============================================
JWT_SECRET=change_this_to_a_very_secure_random_string
JWT_EXPIRES_IN=7d
ALLOW_PUBLIC_REGISTRATION=false

# ============================================
# ADMIN SEED SCRIPT
# ============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_to_a_strong_password
OLD_ADMIN_EMAIL=

# ============================================
# GMAIL API
# ============================================
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/oauth2callback
GMAIL_REFRESH_TOKEN=

# ============================================
# OPENAI
# ============================================
OPENAI_API_KEY=

# ============================================
# ELASTIC EMAIL VALIDATION EVENTS
# Used to ingest transactional delivery/bounce events.
# SuppliKit already sends through Elastic Email; keep secrets out of git.
# ============================================
ELASTIC_EMAIL_API_KEY=
ELASTIC_EMAIL_WEBHOOK_SECRET=
ZEROBOUNCE_API_KEY=
ZEROBOUNCE_API_BASE_URL=https://api-eu.zerobounce.net/v2

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
